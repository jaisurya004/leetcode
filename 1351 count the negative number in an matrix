#include <stdio.h>

int main() {
    int i,j,n,k,l,m,c,r;
    scanf("%d %d",&r,&c);
    int a[r][c];
    for(i=0;i<r;i++){
        for(j=0;j<c;j++){
            scanf("%d",&a[i][j]);
        }
    }
    for(i=0;i<r;i++){
        for(j=0;j<c;j++){
            if(a[i][j]<0)
                n++;
        }
    }
    printf("%d",n);
}

